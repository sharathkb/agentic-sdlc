# Copy to .env and fill in to enable LIVE mode. With no key the system runs in
# deterministic offline MOCK mode automatically.
ANTHROPIC_API_KEY=

# Optional overrides (defaults shown)
AGENTIC_MODEL=claude-sonnet-4-6
AGENTIC_PLANNER_MODEL=claude-opus-4-8
AGENTIC_OUTPUT_DIR=output
AGENTIC_MAX_RETRIES=2
AGENTIC_MAX_PARALLELISM=4
AGENTIC_INTERACTIVE=false
AGENTIC_APPROVAL_REQUIRED_RISK=high
AGENTIC_LOG_LEVEL=INFO
AGENTIC_LOG_JSON=false
# Force offline mode even if a key is present (handy for CI):
AGENTIC_FORCE_MOCK=false
